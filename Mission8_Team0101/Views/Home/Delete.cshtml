@model Mission8_Team0101.Models.Task

@{
    ViewData["Title"] = "Delete Task";
}

<div class="container mt-4">
    <h1>Delete Task</h1>

    <h3>Are you sure you want to delete this task?</h3>

    <div class="card m-3">
        <div class="card-body">
            <h5 class="card-title">@Model.TaskName</h5>
            <p class="card-text">
                @if (Model.DueDate.HasValue)
                {
                    <strong>Due Date:</strong> @Model.DueDate.Value.ToShortDateString()<br />
                }
                <strong>Quadrant:</strong> @Model.Quadrant?.Name<br />
                <strong>Category:</strong> @Model.Category?.Name
            </p>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
