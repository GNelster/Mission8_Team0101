@model Mission8_Team0101.Models.Task
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Task" : "Edit Task";
}

<h2>@(Model.Id == 0 ? "Add Task" : "Edit Task")</h2>

<form asp-controller="Home" asp-action="AddTask" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="TaskName" class="form-label"></label>
            <input asp-for="TaskName" class="form-control" />
            <span asp-validation-for="TaskName" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="DueDate" class="form-label"></label>
            <input asp-for="DueDate" type="date" class="form-control" />
            <span asp-validation-for="DueDate" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="QuadrantId" class="form-label"></label>
            <select asp-for="QuadrantId" asp-items="@ViewBag.Quadrants" class="form-select">
                <option value="">-- Select Quadrant --</option>
            </select>
            <span asp-validation-for="QuadrantId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="CategoryId" class="form-label"></label>
            <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-select">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Save Task</button>
            <a asp-controller="Home" asp-action="Quadrants" class="btn btn-secondary ms-2">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}